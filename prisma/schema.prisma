// prisma/schema.prisma
// Prisma schema for Student Study Portal with MongoDB

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── User & Auth ──────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // hashed, null for OAuth users
  role          Role      @default(STUDENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  student       Student?
  admin         Admin?

  @@map("users")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationTokens")
}

// ─── Student Profile ──────────────────────────────────────────────────────────

model Student {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  userId       String  @unique @db.ObjectId
  rollNumber   String  @unique
  semester     Int     @default(1)
  branch       String
  phone        String?
  address      String?
  dateOfBirth  DateTime?
  avatar       String?
  cgpa         Float   @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  submissions  Submission[]
  attendances  Attendance[]
  quizResults  QuizResult[]
  notifications Notification[]

  @@map("students")
}

model Admin {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  department String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admins")
}

// ─── Notes Module ─────────────────────────────────────────────────────────────

model Note {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  subject     String
  semester    Int
  fileUrl     String
  fileSize    Int?     // bytes
  downloads   Int      @default(0)
  uploadedBy  String   @db.ObjectId
  tags        String[]
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("notes")
}

// ─── Assignment Module ────────────────────────────────────────────────────────

model Assignment {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  subject     String
  semester    Int
  dueDate     DateTime
  totalMarks  Int       @default(100)
  fileUrl     String?   // attachment
  createdBy   String    @db.ObjectId
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  submissions Submission[]

  @@map("assignments")
}

model Submission {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  assignmentId String    @db.ObjectId
  studentId    String    @db.ObjectId
  fileUrl      String
  remarks      String?
  marksObtained Int?
  status       SubmissionStatus @default(PENDING)
  submittedAt  DateTime  @default(now())
  gradedAt     DateTime?

  // Relations
  assignment Assignment @relation(fields: [assignmentId], references: [id])
  student    Student    @relation(fields: [studentId], references: [id])

  @@unique([assignmentId, studentId])
  @@map("submissions")
}

// ─── Quiz Module ──────────────────────────────────────────────────────────────

model Quiz {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  subject     String
  semester    Int
  duration    Int        // minutes
  totalMarks  Int
  passingMarks Int
  createdBy   String     @db.ObjectId
  isActive    Boolean    @default(true)
  startTime   DateTime?
  endTime     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  questions   Question[]
  results     QuizResult[]

  @@map("quizzes")
}

model Question {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  quizId        String   @db.ObjectId
  questionText  String
  options       String[] // A, B, C, D
  correctAnswer Int      // index 0-3
  marks         Int      @default(1)
  explanation   String?
  order         Int

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("questions")
}

model QuizResult {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  quizId      String   @db.ObjectId
  studentId   String   @db.ObjectId
  answers     Int[]    // selected option indices
  score       Int
  percentage  Float
  timeTaken   Int      // seconds
  passed      Boolean
  submittedAt DateTime @default(now())

  quiz    Quiz    @relation(fields: [quizId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@unique([quizId, studentId])
  @@map("quizResults")
}

// ─── Attendance Module ────────────────────────────────────────────────────────

model Attendance {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  studentId String          @db.ObjectId
  subject   String
  date      DateTime
  status    AttendanceStatus @default(PRESENT)
  markedBy  String          @db.ObjectId
  remarks   String?
  createdAt DateTime        @default(now())

  student Student @relation(fields: [studentId], references: [id])

  @@map("attendances")
}

// ─── Timetable Module ─────────────────────────────────────────────────────────

model Timetable {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  semester  Int
  day       DayOfWeek
  startTime String   // "09:00"
  endTime   String   // "10:00"
  subject   String
  teacher   String
  room      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("timetables")
}

// ─── Announcements ────────────────────────────────────────────────────────────

model Announcement {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  content     String
  priority    Priority @default(NORMAL)
  targetRole  Role?    // null = all users
  postedBy    String   @db.ObjectId
  isActive    Boolean  @default(true)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  notifications Notification[]

  @@map("announcements")
}

model Notification {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId      String   @db.ObjectId
  announcementId String?  @db.ObjectId
  title          String
  message        String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  student      Student       @relation(fields: [studentId], references: [id])
  announcement Announcement? @relation(fields: [announcementId], references: [id])

  @@map("notifications")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  STUDENT
  ADMIN
  SUPER_ADMIN
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
  GRADED
  RETURNED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}
